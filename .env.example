# ----------------------------------------------------------
# Datenbank
# ----------------------------------------------------------
# Standard: SQLite (lokal, keine Anmeldung nötig)
DATABASE_URL="file:./dev.db"

# Alternative: Postgres (Supabase, Neon, ...) — siehe README
# Beispiel Supabase:
# DATABASE_URL="postgresql://postgres:PASSWORT@db.xyz.supabase.co:5432/postgres?schema=public"
# Beispiel Neon:
# DATABASE_URL="postgres://USER:PASS@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ----------------------------------------------------------
# NextAuth
# ----------------------------------------------------------
# Erforderlich. In Prod: die echte URL deiner Seite.
NEXTAUTH_URL="http://localhost:3000"
# Erforderlich. Lange zufällige Zeichenkette. Erzeuge z.B. mit:
#   openssl rand -base64 32
NEXTAUTH_SECRET="bitte-zufaellige-zeichenkette-eintragen"

# ----------------------------------------------------------
# OPTIONAL: GitHub OAuth (für späteren Login mit GitHub)
# ----------------------------------------------------------
# GITHUB_ID=""
# GITHUB_SECRET=""

# ----------------------------------------------------------
# OPTIONAL: Email-Magic-Link via Resend
# ----------------------------------------------------------
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@deine-domain.de"
